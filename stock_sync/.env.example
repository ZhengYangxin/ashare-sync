# ==========================================
# 牢A · A股数据同步系统 - 配置示例
# ==========================================
# 复制此文件为 .env
#
# 【零配置部署】.env 文件可以完全留空直接使用！
#   启动后访问 http://localhost:8080 → 数据源配置 填写 Token
#
# 唯一建议设置的是 DB_PASSWORD（生产环境安全需要）：
#
# 复制后运行：
#   docker compose -f docker-compose.hub.yml up -d

# ==========================================
# 【必须】数据库密码（生产环境必须设置）
# ==========================================
# 固定 project name，确保 volume 名称不随执行目录变化
COMPOSE_PROJECT_NAME=ashare-sync

DB_PASSWORD=

# ==========================================
# 【可选】数据库配置（默认已适配 Docker，无需修改）
# ==========================================
DB_TYPE=mysql
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_NAME=ashare

# ==========================================
# 【可选】端口配置
# ==========================================
MYSQL_PORT=3306
WEB_PORT=5000
NGINX_PORT=8080
PMA_PORT=8090

# ==========================================
# 【可选】初始数据导入
# ==========================================
# 首次安装时从母系统下载SQL数据文件
# 方式一：填写母系统的下载地址
# INIT_DATA_URL=http://母系统IP:8080/exports/ashare_data_last.sql
#
# 方式二：将 ashare_data_last.sql 拷贝到 exports 目录（INIT_DATA_URL留空）
# mkdir -p exports && cp /path/to/ashare_data_last.sql exports/
#
# 注意：仅首次安装时导入，系统升级（数据库已有数据）时自动跳过
INIT_DATA_URL=

# ==========================================
# 【可选】其他配置
# ==========================================
TZ=Asia/Shanghai
LOG_LEVEL=INFO
